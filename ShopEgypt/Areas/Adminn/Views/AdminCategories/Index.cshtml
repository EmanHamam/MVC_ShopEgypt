@model List<ShopEgypt.Application.DTOs.CategoryAdminDto>

@{
    ViewData["Title"] = "Categories";
}

<section class="admin-categories-page">
    <div class="admin-page-head">
        <div>
            <h1 class="admin-page-title">Categories</h1>
            <p class="admin-page-meta">@Model.Count total</p>
        </div>

        <a asp-area="Adminn"
           asp-area="Adminn" asp-controller="AdminCategories"
           asp-action="Create"
           class="admin-primary-btn">
            <i class="fa-solid fa-plus"></i>
            <span>New category</span>
        </a>
    </div>

    <div class="admin-categories-grid">
        @foreach (var category in Model)
        {
            <div class="admin-category-card">
                <div class="admin-category-image-wrap">
                    <img src="@(string.IsNullOrWhiteSpace(category.ImageUrl) ? "/images/placeholder.png" : category.ImageUrl)"
                         alt="@category.Name"
                         class="admin-category-image" />
                </div>

                <div class="admin-category-content">
                    <p class="admin-category-count">@category.ProductCount products</p>
                    <h3 class="admin-category-name">@category.Name</h3>
                    <p class="admin-category-description">
                        @(string.IsNullOrWhiteSpace(category.Description) ? "No description available." : category.Description)
                    </p>

                    <div class="admin-category-actions">
                        <a asp-area="Adminn"
                           asp-area="Adminn" asp-controller="AdminCategories"
                           asp-action="Edit"
                           asp-route-id="@category.Id"
                           class="admin-category-edit">
                            <i class="fa-regular fa-pen-to-square"></i>
                            <span>Edit</span>
                        </a>

                        <form asp-area="Adminn"
                              asp-area="Adminn" asp-controller="AdminCategories"
                              asp-action="Delete"
                              method="post"
                              class="admin-delete-form"
                              onsubmit="return confirm('Are you sure you want to delete this category?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@category.Id" />
                            <button type="submit" class="admin-category-delete">
                                <i class="fa-regular fa-trash-can"></i>
                                <span>Delete</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</section>