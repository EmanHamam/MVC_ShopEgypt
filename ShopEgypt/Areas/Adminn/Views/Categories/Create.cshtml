@model ShopEgypt.Application.DTOs.CreateCategoryDto

@{
    ViewData["Title"] = "Create Category";
}

<section class="admin-form-page">
    <div class="admin-form-card">
        <h1 class="admin-page-title">New category</h1>

        <form asp-area="Adminn" asp-controller="Categories" asp-action="Create" method="post" class="admin-form">
            @Html.AntiForgeryToken()

            <div class="admin-form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="admin-input" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="admin-textarea"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="ImageUrl"></label>
                <input asp-for="ImageUrl" class="admin-input" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>

            <div class="admin-form-actions">
                <a asp-area="Adminn" asp-controller="Categories" asp-action="Index" class="admin-secondary-btn">Cancel</a>
                <button type="submit" class="admin-primary-btn">Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}