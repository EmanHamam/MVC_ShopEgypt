@page
@model RegisterModel
@{
    ViewData["Title"] = "Create account";
}

<div class="auth-page">
    <div class="auth-card auth-card--wide">
        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Join ShopEgypt — first order ships free.</p>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            ViewData["ExternalLoginReturnUrl"] = Model.ReturnUrl;
            <partial name="_ExternalLoginButtons" model="Model.ExternalLogins" />
            <div class="auth-or">OR</div>
        }
        else
        {
            <p class="auth-muted-note mb-3">
                External sign-in is not configured yet. Use the form below, or see
                <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank" rel="noopener">Microsoft docs</a>
                to add Google or other providers.
            </p>
        }

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger auth-summary" role="alert"></div>
            <div class="auth-field">
                <label asp-for="Input.FirstName" class="auth-label">First name</label>
                <input asp-for="Input.FirstName" class="auth-input" autocomplete="given-name" aria-required="true" placeholder="First name" />
                <span asp-validation-for="Input.FirstName" class="auth-validation"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.LastName" class="auth-label">Last name</label>
                <input asp-for="Input.LastName" class="auth-input" autocomplete="family-name" aria-required="true" placeholder="Last name" />
                <span asp-validation-for="Input.LastName" class="auth-validation"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.Password" class="auth-label">Password</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="new-password" aria-required="true" placeholder="At least 6 characters" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword" class="auth-label">Confirm password</label>
                <input asp-for="Input.ConfirmPassword" class="auth-input" autocomplete="new-password" aria-required="true" placeholder="Repeat password" />
                <span asp-validation-for="Input.ConfirmPassword" class="auth-validation"></span>
            </div>
            <button id="registerSubmit" type="submit" class="auth-btn auth-btn-register">Create account</button>
        </form>

        <p class="auth-footer-text">
            Already have an account?
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
