@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend confirmation";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Resend confirmation</h1>
        <p class="auth-subtitle">Enter your email and we will send a new confirmation link.</p>

        <form method="post">
            <div asp-validation-summary="All" class="text-danger auth-summary" role="alert"></div>
            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" aria-required="true" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>
            <button type="submit" class="auth-btn auth-btn-register">Send email</button>
        </form>

        <p class="auth-footer-text">
            <a asp-page="./Login" class="auth-link-accent">Back to sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
