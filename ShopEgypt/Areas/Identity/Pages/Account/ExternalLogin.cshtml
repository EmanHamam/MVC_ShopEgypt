@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Complete registration";
}

<div class="auth-page">
    <div class="auth-card auth-card--wide">
        <h1 class="auth-title">Almost done</h1>
        <p class="auth-subtitle">
            You signed in with <strong>@Model.ProviderDisplayName</strong>. Add an email for this site to finish.
        </p>

        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger auth-summary" role="alert"></div>
            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="email" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>
            <button type="submit" class="auth-btn auth-btn-register">Complete account</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
