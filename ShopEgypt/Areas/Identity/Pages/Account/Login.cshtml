@page
@model LoginModel
@{
    ViewData["Title"] = "Sign in";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to continue shopping.</p>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            ViewData["ExternalLoginReturnUrl"] = Model.ReturnUrl;
            <partial name="_ExternalLoginButtons" model="Model.ExternalLogins" />
            <div class="auth-or">OR</div>
        }

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="auth-flash-wrap mb-3">
                <partial name="_FlashAlert" model="(Model.StatusMessage, Model.StatusAlertType)" />
            </div>
        }

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger auth-summary" role="alert"></div>
            <div class="auth-field">
                <label asp-for="Input.Email" class="auth-label">Email</label>
                <input asp-for="Input.Email" class="auth-input" autocomplete="username" aria-required="true" placeholder="you@example.com" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.Password" class="auth-label">Password</label>
                <input asp-for="Input.Password" class="auth-input" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </div>
            <div class="auth-row-between">
                <a id="forgot-password" asp-page="./ForgotPassword" class="auth-link-accent">Forgot password?</a>
            </div>
            <label class="auth-checkbox">
                <input asp-for="Input.RememberMe" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
            <button id="login-submit" type="submit" class="auth-btn auth-btn-signin">Sign in</button>
        </form>

        <p class="auth-footer-text">
            New here?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create an account</a>
        </p>
        <p class="auth-footer-text" style="margin-top: 0.75rem;">
            <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="auth-link-accent">Resend email confirmation</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
