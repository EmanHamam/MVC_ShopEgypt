@page
@model ForgotPasswordConfirmation
@{
    ViewData["Title"] = "Check your email";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">Check your inbox</h1>
        <p class="auth-body-text">
            If an account exists for that email, you will receive a link to reset your password shortly.
        </p>
        <a asp-page="./Login" class="auth-btn auth-btn-signin text-decoration-none">Back to sign in</a>
    </div>
</div>
