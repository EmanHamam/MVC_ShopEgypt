{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=ShopEgypt;Trusted_Connection=True;MultipleActiveResultSets=true",
    "ApplicationDbContextConnection": "Server=(localdb)\\mssqllocaldb;Database=ShopEgypt;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CloudinarySettings": {
    "CloudName": "${CLOUDINARY_CLOUDNAME}",
    "ApiKey": "${CLOUDINARY_APIKEY}",
    "ApiSecret": "${CLOUDINARY_APISECRET}"
  },
  "SendGrid": {
    "ApiKey": "${SENDGRID_APIKEY}",
    "FromEmail": "${SENDGRID_FROMEMAIL}",
    "FromName": "${SENDGRID_FROMNAME}"
  },
  "Stripe": {
    "SecretKey": "${STRIPE_SECRETKEY}"
  },
    "Authentication": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENTID}",
      "ClientSecret": "${GOOGLE_CLIENTSECRET}"
    },
    "Facebook": {
      "AppId": "${FACEBOOK_APPID}",
      "AppSecret": "${FACEBOOK_APPSECRET}"
    }
  }
  
}