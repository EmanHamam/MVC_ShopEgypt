@using ShopEgypt.Application.DTOs
@model ProductDetailDto

<h1>Product Details</h1>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">Title</dt>
    <dd class="col-sm-10">@Model.Title</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price</dd>

    <dt class="col-sm-2">Discount</dt>
    <dd class="col-sm-10">@Model.DiscountPrice</dd>

    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Stock</dd>

    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.CategoryName</dd>

    <dt class="col-sm-2">Rating</dt>
    <dd class="col-sm-10">@Model.AverageRating</dd>
</dl>

<h3>Images</h3>
@if (Model.Images != null && Model.Images.Count > 0)
{
    <ul>
    @foreach (var img in Model.Images)
    {
        <li>
            <img src="@img.ImageUrl" alt="Product image" style="max-width: 150px;" />
        </li>
    }
    </ul>
}
else
{
    <p>No images.</p>
}

<p>
    <a href="/products/edit/@Model.Id">Edit</a> |
    <a href="/products/delete/@Model.Id">Delete</a> |
    <a href="/products">Back</a>
</p>


<hr />

<h3>Add a Review</h3>
<form asp-controller="Reviews" asp-action="Create" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="ProductId" value="@Model.Id" />
    {{!-- replace with actual logged-in user id --}}
    <input type="hidden" name="ApplicationUserId" value="267824f8-683c-4812-afc8-1e1dbdafe519" />

    <div class="mb-3">
        <label class="form-label">Rating (1-5)</label>
        <input type="number" name="Rating" min="1" max="5" class="form-control" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Comment</label>
        <textarea name="Comment" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Submit Review</button>
</form>

<p class="mt-3">
    <a href="/products/edit/@Model.Id">Edit</a> |
    <a href="/products/delete/@Model.Id">Delete</a> |
    <a href="/products">Back</a>
</p>