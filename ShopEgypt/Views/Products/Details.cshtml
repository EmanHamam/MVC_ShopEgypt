@using ShopEgypt.Application.DTOs
@model ProductDetailDto

@{
    var hasDiscount = Model.DiscountPrice.HasValue && Model.DiscountPrice.Value > 0;
    var finalPrice = hasDiscount ? Model.DiscountPrice!.Value : Model.Price;
    var heroImage = Model.Images?.FirstOrDefault()?.ImageUrl ?? "/images/placeholder.png";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var rating = Model.AverageRating.ToString("0.0");
    var reviews = Model.ReviewCount;
    var colors = Model.Color;
    var sizes = Model.Size;

}

<section class="product-detail">
    <div class="container product-detail-grid">
        <div class="product-gallery">
            <nav class="product-breadcrumb">
                <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-area="" asp-controller="Products" asp-action="Index">Shop</a>
                <span>/</span>
                <span>@Model.Title</span>
            </nav>

            <div class="product-hero-image">
                <img src="@heroImage" alt="@Model.Title" />
            </div>

            <div class="product-thumbs">
                @if (Model.Images != null && Model.Images.Count > 0)
                {
                    foreach (var img in Model.Images)
                    {
                        <button type="button" class="product-thumb" data-image="@img.ImageUrl">
                            <img src="@img.ImageUrl" alt="@Model.Title" />
                        </button>
                    }
                }
            </div>
        </div>

        <div class="product-detail-info">
            <span class="product-brand">@Model.Brand</span>
            <h1>@Model.Title</h1>

            <div class="product-rating-row">
                <span class="stars" aria-hidden="true">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Floor(Model.AverageRating))
                        {
                            @:★
                        }
                        else if (i == Math.Ceiling(Model.AverageRating) && Model.AverageRating % 1 >= 0.5)
                        {
                            @:★
                        }
                        else
                        {
                            @:☆
                        }
                    }
                </span>
                <span>@rating • @reviews reviews</span>
            </div>

            <div class="product-detail-price">
                <span class="price">@Model.DiscountPrice?.ToString("N0")  EGP</span>
                @if (hasDiscount)
                {
                    <span class="price-old">@Model.Price.ToString("N0")</span>
                }
            </div>

            <p class="product-description">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "A refined everyday staple crafted by Egypt's thoughtful makers."
                    : Model.Description)
            </p>

  
            <div class="product-option">
                <h4>Color</h4>
                <div class="color-dots">
                    <span class="colors">@colors</span>
                </div>
            </div>

            <div class="product-option">
                <h4>Size</h4>
                <div class="size-pills">
                    <button type="button" class="size-pill is-active">@sizes</button>
                </div>
            </div>

            <div class="product-option">
                <h4>Quantity</h4>
                <div class="qty-control" data-min="1">
                    <button type="button" class="qty-btn" data-step="-1">−</button>
                    <input type="number" name="qty" value="1" min="1" />
                    <button type="button" class="qty-btn" data-step="1">+</button>
                </div>
            </div>

    <div class="review-form-card">
            <div class="product-cta">
                <form asp-controller="Cart" asp-action="Add" method="post" class="add-to-bag">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <input type="hidden" name="qty" value="1" />
                    <button type="submit">Add to bag</button>
                </form>
                <form asp-controller="WishListItems" asp-action="Add" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <button type="submit" class="wishlist-circle" aria-label="Add to wishlist">
                        <i class="fa-regular fa-heart"></i>
                    </button>
                </form>
            </div>

            <div class="product-meta-row">
                <span><i class="fa-regular fa-circle-check"></i> Free shipping</span>
                <span><i class="fa-regular fa-clock"></i> 30-day returns</span>
                <span><i class="fa-regular fa-gem"></i> Authentic</span>
            </div>
        </div>
    </div>
</section>

<section class="product-reviews">
    <div class="container">
        <div class="reviews-header">
            <h2>Customer reviews</h2>
        </div>
    </div>
    <div class="container">
      <!-- Review Sort Dropdown -->
      <div style="margin-bottom: 1rem;">
        <label for="reviewSort" style="font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 0.85rem; color: #9a9085; margin-right: 0.5rem;">Sort Reviews:</label>
        <select id="reviewSort" onchange="window.location.href = '?reviewSort=' + this.value" style="padding: 0.5rem; border: 1px solid #e0d8cd; border-radius: 8px; background: #f0ece5; font-size: 0.85rem;">
            <option value="newest" selected="@(ViewBag.ReviewSort == "newest")">Newest</option>
            <option value="highest" selected="@(ViewBag.ReviewSort == "highest")">Highest Rating</option>
            <option value="lowest" selected="@(ViewBag.ReviewSort == "lowest")">Lowest Rating</option>
        </select>
      </div>

      <div class="review-form-card">
        <form asp-area="" asp-controller="Reviews" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProductId" value="@Model.Id" />
            <input type="hidden" name=ApplicationUserId value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />

            <div class="form-group">
                <label class="form-label">Your Rating</label>
                <div class="star-rating-input">
                    @for (int i = 5; i >= 1; i--)
                    {
                        <input type="radio" id="star@(i)" name="Rating" value="@i" required />
                        <label for="star@(i)" title="@i stars">&#9733;</label>
                    }
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="reviewComment">Share Your Experience</label>
                <textarea id="reviewComment" name="Comment"  class="form-control"
                          placeholder="Tell others what you think about this product..."></textarea>
            </div>

            <button type="submit" class="btn-submit-review">Submit Review</button>
        </form>
    </div>

    @if (Model.ProductReviews != null && Model.ProductReviews.Any())
    {
        <div class="reviews-list">
            @foreach (var review in Model.ProductReviews)
            {
                <div class="review-card">
                    <div class="review-card-header">
                        @* <span class="review-author">@review.ApplicationUser?.FirstName</span> *@
                        <strong>@review.UserName</strong>
                        <span class="review-date">@review.CreatedAt?.ToString("MMM d, yyyy")</span>
                        @if (User.Identity?.IsAuthenticated == true &&
                             User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == review.ApplicationUserId)
                        {
                            <a href="/reviews/edit/@review.Id" style="margin-left: 1rem; color: #7a7060; text-decoration: none;">Edit</a>
                        }
                    </div>
                    <div class="review-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@(i <= review.Rating ? "★" : "☆")</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <p class="review-comment">@review.Comment</p>
                    }
                </div>
            }
        </div>
    } 
    else
    {
        <div class="reviews-empty">
            No reviews yet. Be the first to share your thoughts.
        </div>
    }
    </div>
</section>
