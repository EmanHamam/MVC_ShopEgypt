@using ShopEgypt.Application.DTOs
@model ProductDetailDto

@{
    var hasDiscount = Model.DiscountPrice.HasValue && Model.DiscountPrice.Value > 0;
    var finalPrice = hasDiscount ? Model.Price - Model.DiscountPrice!.Value : Model.Price;
    var heroImage = Model.Images?.FirstOrDefault()?.ImageUrl ?? "/images/placeholder.png";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var rating = Model.AverageRating.ToString("0.0");
    var reviews = Model.ReviewCount;
    var colors = Model.Color;
    var sizes = Model.Size;

}

<section class="product-detail">
    <div class="container product-detail-grid">
        <div class="product-gallery">
            <nav class="product-breadcrumb">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span>/</span>
                <a asp-controller="Products" asp-action="Index">Shop</a>
                <span>/</span>
                <span>@Model.Title</span>
            </nav>

            <div class="product-hero-image">
                <img src="@heroImage" alt="@Model.Title" />
            </div>

            <div class="product-thumbs">
                @if (Model.Images != null && Model.Images.Count > 0)
                {
                    foreach (var img in Model.Images)
                    {
                        <button type="button" class="product-thumb" data-image="@img.ImageUrl">
                            <img src="@img.ImageUrl" alt="@Model.Title" />
                        </button>
                    }
                }
            </div>
        </div>

        <div class="product-detail-info">
            <span class="product-brand">@Model.Brand</span>
            <h1>@Model.Title</h1>

            <div class="product-rating-row">
                <span class="stars" aria-hidden="true">★★★★★</span>
                <span>@rating • @reviews reviews</span>
            </div>

            <div class="product-detail-price">
                <span class="price">@finalPrice.ToString("N0") EGP</span>
                @if (hasDiscount)
                {
                    <span class="price-old">@Model.Price.ToString("N0")</span>
                }
            </div>

            <p class="product-description">
                @(string.IsNullOrWhiteSpace(Model.Description)
                    ? "A refined everyday staple crafted by Egypt's thoughtful makers."
                    : Model.Description)
            </p>

            <div class="product-option">
                <h4>Color</h4>
                <div class="color-dots">
                    <span class="colors">@colors</span>
                </div>
            </div>

            <div class="product-option">
                <h4>Size</h4>
                <div class="size-pills">
                    <button type="button" class="size-pill is-active">@sizes</button>
                </div>
            </div>

            <div class="product-option">
                <h4>Quantity</h4>
                <div class="qty-control" data-min="1">
                    <button type="button" class="qty-btn" data-step="-1">−</button>
                    <input type="number" name="qty" value="1" min="1" />
                    <button type="button" class="qty-btn" data-step="1">+</button>
                </div>
            </div>

            <div class="product-cta">
                <form asp-controller="Cart" asp-action="Add" method="post" class="add-to-bag">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <input type="hidden" name="qty" value="1" />
                    <button type="submit">Add to bag</button>
                </form>
                <button type="button" class="wishlist-circle" aria-label="Add to wishlist">
                    <i class="fa-regular fa-heart"></i>
                </button>
            </div>

            <div class="product-meta-row">
                <span><i class="fa-regular fa-circle-check"></i> Free shipping</span>
                <span><i class="fa-regular fa-clock"></i> 30-day returns</span>
                <span><i class="fa-regular fa-gem"></i> Authentic</span>
            </div>
        </div>
    </div>
</section>

<section class="product-reviews">
    <div class="container">
        <div class="reviews-header">
            <h2>Customer reviews</h2>
            <button type="button" class="review-btn">Write a review</button>
        </div>
    </div>
</section>
