@using ShopEgypt.Application.DTOs
@using ShopEgypt.Domain.Enums.ProductEnums
@model PagedResultDto<ProductListItemDto>

@using Microsoft.AspNetCore.Mvc.Rendering

@{
    var categories = (SelectList)ViewBag.Categories;
    var selectedCategoryId = (int?)ViewBag.SelectedCategoryId;
    var sortBy = (ProductSortBy?)ViewBag.SortBy;
    var keyword = (string)ViewBag.KeyWord;
    var sortItems = Html.GetEnumSelectList<ProductSortBy>().ToList();
    var selectedSortValue = sortBy.HasValue ? ((int)sortBy.Value).ToString() : string.Empty;
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var minPriceValue = minPrice?.ToString("0.##") ?? string.Empty;
    var maxPriceValue = maxPrice?.ToString("0.##") ?? string.Empty;
    var currentPage = ViewBag.Page as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 12;
    var totalPages = (int)Math.Ceiling(Model.TotalCount / (double)pageSize);
    foreach (var item in sortItems)
    {
        item.Selected = item.Value == selectedSortValue;
    }
}

<section class="product-hero">
    <div class="container product-hero-inner">
        <div>
            <h1>The full edit.</h1>
            <p>@Model.TotalCount products from Egypt's most thoughtful makers.</p>
        </div>
    </div>
</section>

<section class="product-catalog">
    <div class="container product-catalog-grid">
        <aside class="product-filters">
            <div class="filter-block">
                <h3>Category</h3>
                <div class="filter-list">
                    <a href="/products?categoryId=&sortBy=@selectedSortValue&keyWord=@keyword&minPrice=@minPriceValue&maxPrice=@maxPriceValue"
                       class="@(selectedCategoryId.HasValue ? string.Empty : "is-active")">
                        All
                    </a>
                    @foreach (var category in categories)
                    {
                        <a href="/products?categoryId=@category.Value&sortBy=@selectedSortValue&keyWord=@keyword&minPrice=@minPriceValue&maxPrice=@maxPriceValue"
                           class="@(selectedCategoryId.HasValue && selectedCategoryId.Value.ToString() == category.Value ? "is-active" : string.Empty)">
                            @category.Text
                        </a>
                    }
                </div>
            </div>

            <div class="filter-block">
                <h3>Price</h3>
                <div class="price-fields">
                    <input type="number" name="minPrice" min="0" step="1" placeholder="Min" value="@minPriceValue" form="productFilterForm" />
                    <span>to</span>
                    <input type="number" name="maxPrice" min="0" step="1" placeholder="Max" value="@maxPriceValue" form="productFilterForm" />
                </div>
            </div>
        </aside>

        <div class="product-main">
            <form method="get" action="/products" class="product-toolbar product-filter-form" data-auto-submit="true" id="productFilterForm">
                <label class="product-search">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" name="keyWord" value="@keyword" placeholder="Search products" />
                </label>

                <div class="product-results">@Model.TotalCount results</div>

                <select name="sortBy" class="product-sort" asp-items="sortItems">
                    <option value="" selected="@(string.IsNullOrEmpty(selectedSortValue) ? "selected" : null)">Featured</option>
                </select>

                <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                <button type="submit" class="product-apply">Apply</button>
            </form>

            <div class="product-grid">
                @foreach (var item in Model.Items)
                {
                    var hasDiscount = item.DiscountPrice.HasValue && item.DiscountPrice.Value > 0;
                    var badge = item.AverageRating >= 4.5 ? "Bestseller" : (hasDiscount ? "Sale" : "New");
                    <article class="product-card">
                        <div class="product-media">
                            <a href="/products/details/@item.Id" class="product-media-link">
                                <img src="@(item.ThumbnailUrl ?? "/images/placeholder.png")" alt="@item.Title" />
                            </a>
                            <span class="product-badge">@badge</span>
                            <form action="/Wishlist/Add" method="post" style="display: inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="wishlist-btn" aria-label="Add to wishlist">
                                    <i class="fa-regular fa-heart"></i>
                                </button>
                            </form>

                            
                            <form action="/Cart/Add" method="post" class="product-add">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="qty" value="1" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit">Add to bag</button>
                            </form>
                        </div>

                        <div class="product-info">
                            <div class="product-meta">
                                <span>@item.ReviewCount reviews</span>
                                <span class="product-rating">
                                    <i class="fa-solid fa-star"></i>
                                    @item.AverageRating.ToString("0.0")
                                </span>
                            </div>
                            <div class="product-brand">@item.Brand</div>
                            <a href="/products/details/@item.Id" class="product-title">
                                @item.Title
                            </a>
                            <div class="product-price">
                                <span>@item.DiscountPrice?.ToString("N0") EGP</span>
                                @if (hasDiscount && item.DiscountPrice != item.Price)
                                {
                                    <span class="product-price-old">@item.Price.ToString("N0") EGP</span>
                                }
                            </div>
                        </div>
                    </article>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="product-pagination">
                    @if (currentPage > 1)
                    {
                        <a class="page-btn" href="/products?page=@(currentPage - 1)&pageSize=@pageSize&categoryId=@selectedCategoryId&sortBy=@selectedSortValue&keyWord=@keyword&minPrice=@minPriceValue&maxPrice=@maxPriceValue">
                            Previous
                        </a>
                    }
                    else
                    {
                        <span class="page-btn is-disabled">Previous</span>
                    }

                    <span class="page-status">Page @currentPage of @totalPages</span>

                    @if (currentPage < totalPages)
                    {
                        <a class="page-btn" href="/products?page=@(currentPage + 1)&pageSize=@pageSize&categoryId=@selectedCategoryId&sortBy=@selectedSortValue&keyWord=@keyword&minPrice=@minPriceValue&maxPrice=@maxPriceValue">
                            Next
                        </a>
                    }
                    else
                    {
                        <span class="page-btn is-disabled">Next</span>
                    }
                </div>
            }
        </div>
    </div>
</section>
