@using ShopEgypt.Domain.Entities
@model Product

<h1>Edit Product</h1>

<form action="/products/edit/@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <input name="Id" type="hidden" value="@Model.Id" />

    <div class="mb-3">
        <label>Title</label>
        <input name="Title" class="form-control" value="@Model.Title" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <textarea name="Description" class="form-control">@Model.Description</textarea>
    </div>

    <div class="mb-3">
        <label>Price</label>
        <input name="Price" type="number" step="0.01" class="form-control" value="@Model.Price" />
    </div>

    <div class="mb-3">
        <label>Discount Price</label>
        <input name="DiscountPrice" type="number" step="0.01" class="form-control" value="@Model.DiscountPrice" />
    </div>

    <div class="mb-3">
        <label>Stock</label>
        <input name="Stock" type="number" class="form-control" value="@Model.Stock" />
    </div>

    <div class="mb-3">
        <label>Category Id</label>
        <input name="CategoryId" type="number" class="form-control" value="@Model.CategoryId" />
    </div>

    <div class="mb-3">
        <label>Seller Id</label>
        <input name="SellerId" class="form-control" value="@Model.SellerId" />
    </div>

    <div class="mb-3">
        <label>Is Active</label>
        <input name="IsActive" type="checkbox" value="true" @(Model.IsActive ? "checked" : "") />
    </div>

    <div class="mb-3">
        <label>Images (optional)</label>
        <input name="images" type="file" multiple class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/products/details/@Model.Id">Cancel</a>
</form>
