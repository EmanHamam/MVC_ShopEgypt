@using Microsoft.AspNetCore.Identity
@using ShopEgypt.Domain.Entities
@using ShopEgypt.ViewModels.Header
@model HeaderViewModel
@inject SignInManager<ApplicationUser> SignInManager

@if (SignInManager.IsSignedIn(User))
{
    var displayName = !string.IsNullOrWhiteSpace(Model?.UserGreetingName)
        ? Model.UserGreetingName
        : User.Identity?.Name;
    <div class="user-greeting">
        <i class="fa-solid fa-user-circle" aria-hidden="true"></i>
        <span>Hello  @displayName</span>
        <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/products" method="post" class="user-greeting-logout">
            <button type="submit" class="logout-btn">Logout</button>
        </form>
    </div>
}
else
{
    <div class="auth-links">
        <a asp-area="Identity" asp-page="/Account/Register">Register</a>
        <a asp-area="Identity" asp-page="/Account/Login" class="login-btn">Login</a>
    </div>
}
