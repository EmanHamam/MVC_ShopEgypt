<footer class="site-footer">
    <div class="container footer-grid">
        <div class="footer-brand">
            <div class="footer-logo">
                <span class="logo-dot"></span>
                <span class="logo-text">ShopEgypt</span>
            </div>

            <p>
                A curated marketplace for Egypt's finest makers. Linen,
                leather, ceramic and scent — delivered with care.
            </p>

            <div class="social-links">
                <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
            </div>
        </div>

        <div class="footer-column">
            <h4>Shop</h4>
            <ul>
                <li><a asp-controller="Shop" asp-action="Index">All Products</a></li>
                <li><a asp-controller="Categories" asp-action="Index">Categories</a></li>
                <li><a asp-controller="Shop" asp-action="Index">New Arrivals</a></li>
                <li><a asp-controller="Shop" asp-action="Index">Sale</a></li>
            </ul>
        </div>

        <div class="footer-column">
            <h4>Support</h4>
            <ul>
                <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                <li><a asp-controller="Home" asp-action="Contact">Shipping</a></li>
                <li><a asp-controller="Home" asp-action="Contact">Returns</a></li>
                <li><a asp-controller="Home" asp-action="Contact">FAQ</a></li>
            </ul>
        </div>

        <div class="footer-column">
            <h4>Brand</h4>
            <ul>
                <li><a asp-controller="Home" asp-action="About">About</a></li>
                <li><a asp-controller="Home" asp-action="About">Journal</a></li>
                <li><a asp-controller="Home" asp-action="About">Press</a></li>
                <li><a asp-controller="Home" asp-action="About">Careers</a></li>
            </ul>
        </div>
    </div>

    <div class="footer-bottom">
        © @DateTime.Now.Year ShopEgypt. Crafted with care in Smart Village (IDA46).
    </div>
