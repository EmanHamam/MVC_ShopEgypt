@model ShopEgypt.Application.DTOs.OrdersDTO.OrderDTO

@{
    ViewData["Title"] = "Order Summary";
}

<div class="checkout-container">
    <!-- Step Indicator -->
    <div class="checkout-steps mb-5">
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Address</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step active">
            <div class="step-circle">2</div>
            <span>Summary</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">3</div>
            <span>Payment</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">4</div>
            <span>Confirmed</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- Order Items -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-bag me-2 text-primary"></i>Order Items
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderItems != null && Model.OrderItems.Any())
                                {
                                    foreach (var item in Model.OrderItems)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@item.ProductName</div>
                                                @if (!string.IsNullOrEmpty(item.ProductDescription))
                                                {
                                                    <div class="text-muted small">
                                                        @(item.ProductDescription.Length > 60
                                                            ? item.ProductDescription[..60] + "…"
                                                            : item.ProductDescription)
                                                    </div>
                                                }
                                            </td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">EGP @item.UnitPrice.ToString("F2")</td>
                                            <td class="text-end fw-semibold">EGP @((item.UnitPrice * item.Quantity).ToString("F2"))</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            <i class="bi bi-bag-x fs-3 d-block mb-2"></i>
                                            No items found.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Shipping Address -->
            @if (Model.Address != null)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-geo-alt me-2 text-primary"></i>Shipping Address
                        </h5>
                        <address class="mb-0">
                            <div>@Model.Address.Street</div>
                            <div>@Model.Address.City@(Model.Address.State != null ? ", " + Model.Address.State : "")</div>
                            @if (!string.IsNullOrEmpty(Model.Address.ZipCode))
                            {
                                <div>@Model.Address.ZipCode</div>
                            }
                            <div>@Model.Address.Country</div>
                        </address>
                    </div>
                </div>
            }
        </div>

        <!-- Order Total & Confirm -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-lg-top" style="top: 1rem;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4">Order Total</h5>

                    <div class="d-flex justify-content-between mb-2 text-muted">
                        <span>Subtotal</span>
                        <span>EGP @Model.TotalAmount.ToString("F2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Shipping</span>
                        <span class="text-success">@(Model.TotalAmount > 1500 ? "Free" : "EGP 80.00")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span>EGP @((Model.TotalAmount > 1500 ? Model.TotalAmount : Model.TotalAmount + 80).ToString("F2"))</span>
                    </div>

                    <form asp-action="ConfirmOrder" asp-controller="ShopOrders" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3">
                                <i class="bi bi-credit-card me-2"></i>Confirm & Pay
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <a asp-action="Address" class="text-muted small">
                            <i class="bi bi-arrow-left me-1"></i> Edit Address
                        </a>
                    </div>

                    <div class="text-center mt-3">
                        <small class="text-muted">
                            <i class="bi bi-shield-lock me-1"></i>
                            Secure checkout powered by Stripe
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-container { max-width: 1000px; margin: 2rem auto; padding: 0 1rem; }

    .checkout-steps {
        display: flex; align-items: center; justify-content: center;
    }
    .step {
        display: flex; flex-direction: column; align-items: center; gap: .3rem;
        font-size: .8rem; color: #aaa; min-width: 70px;
    }
    .step.active .step-circle { background: #0d6efd; color: #fff; }
    .step.done  .step-circle  { background: #198754; color: #fff; }
    .step-circle {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: #e9ecef; font-weight: 700; font-size: .9rem;
    }
    .step-line      { flex: 1; height: 2px; background: #dee2e6; margin: 0 .5rem; margin-bottom: 1.2rem; }
    .step-line.done-line { background: #198754; }
</style>
