<!-- ===== HERO SECTION ===== -->
<section class="hero-section">
    <div class="hero-content">
        <p class="hero-label">— SPRING EDIT 2026</p>
        <h1 class="hero-heading">
            Stay grounded.<br>
            <span class="hero-heading-accent">Live beautifully.</span>
        </h1>
