@model ShopEgypt.Application.DTOs.OrdersDTO.OrderDTO

@{
    ViewData["Title"] = "Order Confirmed!";
}

<div class="checkout-container">
    <!-- Step Indicator -->
    <div class="checkout-steps mb-5">
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Address</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Summary</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Payment</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step active">
            <div class="step-circle"><i class="bi bi-check-lg"></i></div>
            <span>Confirmed</span>
        </div>
    </div>

    <!-- Success Banner -->
    <div class="text-center mb-5">
        <div class="success-icon mb-3">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
        </div>
        <h1 class="fw-bold">Thank you for your order!</h1>
        <p class="text-muted fs-5">
            Your order has been confirmed and is now being processed.
        </p>
        <div class="badge bg-success-subtle text-success border border-success-subtle fs-6 px-3 py-2 rounded-pill">
            <i class="bi bi-bag-check me-1"></i> Order #@Model.OrderId — @Model.OrderStatus
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Order Items -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-bag me-2 text-primary"></i>Items Ordered
                    </h5>
                    <div class="table-responsive">
                        <table class="table table-borderless align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th>Product</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.ProductName</div>
                                        </td>
                                        <td class="text-center">@item.Quantity</td>
                                        <td class="text-end">EGP @item.UnitPrice.ToString("F2")</td>
                                        <td class="text-end fw-semibold">EGP @((item.UnitPrice * item.Quantity).ToString("F2"))</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="border-top">
                                @{
                                    decimal shipping   = ViewBag.ShippingFee ?? 0;
                                    decimal grandTotal = ViewBag.GrandTotal;
                                }
                                <tr class="text-muted">
                                    <td colspan="3" class="text-end">Subtotal</td>
                                    <td class="text-end">EGP @(Model.TotalAmount-shipping)</td>
                                </tr>
                                <tr class="text-muted">
                                    <td colspan="3" class="text-end">Shipping</td>
                                    <td class="text-end @(shipping == 0 ? "text-success" : "")">
                                        @(shipping == 0 ? "Free" : "EGP 80.00")
                                    </td>
                                </tr>
                                <tr class="border-top">
                                    <td colspan="3" class="text-end fw-bold fs-6">Grand Total</td>
                                    <td class="text-end fw-bold fs-5 text-primary">
                                        EGP @grandTotal.ToString("F2")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Shipping Address -->
            @if (Model.Address != null)
            {
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-geo-alt me-2 text-primary"></i>Delivery Address
                        </h5>
                        <address class="mb-0 text-muted">
                            <div>@Model.Address.Street</div>
                            <div>@Model.Address.City@(Model.Address.State != null ? ", " + Model.Address.State : "")</div>
                            @if (!string.IsNullOrEmpty(Model.Address.ZipCode))
                            {
                                <div>@Model.Address.ZipCode</div>
                            }
                            <div>@Model.Address.Country</div>
                        </address>
                    </div>
                </div>
            }

            <!-- CTA Buttons -->
            <div class="d-flex gap-3 flex-wrap">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-3 flex-fill">
                    <i class="bi bi-shop me-2"></i>Continue Shopping
                </a>
                <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-secondary btn-lg rounded-3 flex-fill">
                    <i class="bi bi-list-check me-2"></i>My Orders
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }

    .checkout-steps {
        display: flex; align-items: center; justify-content: center;
    }
    .step {
        display: flex; flex-direction: column; align-items: center; gap: .3rem;
        font-size: .8rem; color: #aaa; min-width: 70px;
    }
    .step.active .step-circle { background: #198754; color: #fff; }
    .step.done  .step-circle  { background: #198754; color: #fff; }
    .step-circle {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: #e9ecef; font-weight: 700; font-size: .9rem;
    }
    .step-line           { flex: 1; height: 2px; background: #dee2e6; margin: 0 .5rem; margin-bottom: 1.2rem; }
    .step-line.done-line { background: #198754; }

    .success-icon { animation: pop .4s ease; }
    @@keyframes pop {
        0%   { transform: scale(0.5); opacity: 0; }
        80%  { transform: scale(1.15); }
        100% { transform: scale(1); opacity: 1; }
    }
</style>
