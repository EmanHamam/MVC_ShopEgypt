@using ShopEgypt.Domain.Enums
@model ShopEgypt.Application.DTOs.OrdersDTO.OrderListViewModel

@{
    ViewData["Title"] = "My Orders";
    var orders = Model.Orders;
}

<section class="orders-page">
    <div class="orders-wrapper">
        <div class="orders-heading">
            <div>
                <h1>My Orders</h1>
                <p>@Model.TotalOrders @(Model.TotalOrders == 1 ? "order" : "orders") placed from your account.</p>
            </div>
        </div>

        @if (!orders.Any())
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-5 text-center">
                    <div class="orders-empty-icon mb-3">
                        <i class="fa-solid fa-box-open"></i>
                    </div>
                    <h2 class="fw-bold mb-2">No orders yet.</h2>
                    <p class="text-muted mb-4">Your order history will appear here after you place your first order.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-3">
                        Start shopping
                    </a>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 orders-table">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th scope="col">Order</th>
                                    <th scope="col">Date</th>
                                    <th scope="col" class="text-center">Status</th>
                                    <th scope="col" class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in orders)
                                {
                                    var statusClass = order.OrderStatus switch
                                    {
                                        OrderStatus.Pending => "bg-secondary text-white",
                                        OrderStatus.Confirmed => "bg-primary text-white",
                                        OrderStatus.Processing => "bg-warning text-dark",
                                        OrderStatus.Shipped => "bg-info text-dark",
                                        OrderStatus.Delivered => "bg-success text-white",
                                        OrderStatus.Cancelled => "bg-danger text-white",
                                        _ => "bg-secondary text-white"
                                    };

                                    <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Detail", "Orders", new { orderId = order.OrderId })'">
                                        <td>
                                            <div class="fw-semibold">#@order.OrderId</div>
                                            <div class="text-muted small">@order.OrderItems.Count items</div>
                                        </td>
                                        <td>
                                            <div class="fw-medium">@order.OrderDate.ToString("MMM dd, yyyy")</div>
                                            <div class="text-muted small">@order.OrderDate.ToString("hh:mm tt")</div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="rounded-pill @statusClass py-1 px-2 fw-bold" style="display: inline-block; width: 100px; font-size: 0.85rem; position: static !important;">
                                                @order.OrderStatus.ToString()
                                            </span>
                                        </td>
                                        <td class="text-end fw-bold fs-6">
                                            @order.TotalAmount.ToString("N0") EGP
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Pagination Controls -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="MyOrders" asp-route-page="@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                            <a class="page-link" asp-action="MyOrders" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</section>

<style>
    .orders-page {
        max-width: 1100px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .orders-wrapper {
        display: grid;
        gap: 1.25rem;
    }

    .orders-heading h1 {
        font-size: clamp(2rem, 3vw, 2.75rem);
        font-weight: 800;
        margin-bottom: .35rem;
    }

    .orders-heading p {
        color: #6c757d;
        margin: 0;
    }

    .orders-table thead th {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #e9ecef;
    }

    .orders-table tbody td {
        padding: 1rem 1.25rem;
        border-color: #f1f3f5;
    }
    
    .orders-table tbody tr:hover {
        background-color: #f8f9fa;
    }



    .orders-empty-icon {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: #0d6efd;
    }
</style>
