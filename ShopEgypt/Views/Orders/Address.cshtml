@model ShopEgypt.Application.DTOs.OrdersDTO.AddressDTO

@{
    ViewData["Title"] = "Shipping Address";
}

<div class="checkout-container">
    <!-- Step Indicator -->
    <div class="checkout-steps mb-5">
        <div class="step active">
            <div class="step-circle">1</div>
            <span>Address</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">2</div>
            <span>Summary</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">3</div>
            <span>Payment</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">4</div>
            <span>Confirmed</span>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h2 class="fw-bold mb-1">Shipping Address</h2>
                    <p class="text-muted mb-4">Where should we deliver your order?</p>

                    <form asp-controller="Orders" asp-action="Address" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Street" class="form-label fw-semibold"></label>
                            <input asp-for="Street" class="form-control form-control-lg"
                                   placeholder="e.g. 12 Tahrir Square" />
                            <span asp-validation-for="Street" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="City" class="form-label fw-semibold"></label>
                                <input asp-for="City" class="form-control"
                                       placeholder="e.g. Cairo" />
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="State" class="form-label fw-semibold"></label>
                                <input asp-for="State" class="form-control"
                                       placeholder="e.g. Cairo Governorate" />
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="ZipCode" class="form-label fw-semibold"></label>
                                <input asp-for="ZipCode" class="form-control" placeholder="e.g. 11511" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Country" class="form-label fw-semibold"></label>
                                <input asp-for="Country" class="form-control" value="Egypt" />
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3">
                                Continue to Summary <i class="bi bi-arrow-right ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <a asp-controller="Cart" asp-action="Index" class="text-muted small">
                    <i class="bi bi-arrow-left me-1"></i> Back to Cart
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .checkout-container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }

    .checkout-steps {
        display: flex; align-items: center; justify-content: center;
    }
    .step {
        display: flex; flex-direction: column; align-items: center; gap: .3rem;
        font-size: .8rem; color: #aaa; min-width: 70px;
    }
    .step.active .step-circle { background: #0d6efd; color: #fff; }
    .step.done  .step-circle  { background: #198754; color: #fff; }
    .step-circle {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: #e9ecef; font-weight: 700; font-size: .9rem;
    }
    .step-line { flex: 1; height: 2px; background: #dee2e6; margin: 0 .5rem; margin-bottom: 1.2rem; }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
