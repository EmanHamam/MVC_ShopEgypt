@{
    ViewData["Title"] = "Payment";

    string clientSecret   = ViewBag.ClientSecret;
    string publishableKey = ViewBag.PublishableKey;
    string totalAmount    = ViewBag.TotalAmount ?? "0.00";
    string orderId        = ViewBag.OrderId;
}

<div class="checkout-container">
    <!-- Step Indicator -->
    <div class="checkout-steps mb-5">
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Address</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step done">
            <div class="step-circle"><i class="bi bi-check"></i></div>
            <span>Summary</span>
        </div>
        <div class="step-line done-line"></div>
        <div class="step active">
            <div class="step-circle">3</div>
            <span>Payment</span>
        </div>
        <div class="step-line"></div>
        <div class="step">
            <div class="step-circle">4</div>
            <span>Confirmed</span>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h2 class="fw-bold mb-1">Secure Payment</h2>
                    <p class="text-muted mb-4">
                        <i class="bi bi-shield-lock-fill text-success me-1"></i>
                        Your payment is encrypted and secure
                    </p>

                    <!-- Amount Banner -->
                    <div class="alert alert-light border rounded-3 d-flex justify-content-between align-items-center mb-4">
                        <span class="text-muted">Amount Due</span>
                        <span class="fw-bold fs-5">EGP @totalAmount</span>
                    </div>

                    <!-- Stripe Card Element -->
                    <div id="payment-element" class="mb-3"></div>
                    <div id="payment-message" class="alert alert-danger d-none mb-3" role="alert"></div>

                    <div class="d-grid">
                        <button id="pay-btn" class="btn btn-primary btn-lg rounded-3">
                            <span id="pay-btn-text">
                                <i class="bi bi-lock-fill me-2"></i>Pay EGP @totalAmount
                            </span>
                            <span id="pay-spinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
                        </button>
                    </div>

                    <div class="text-center mt-3">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/b/ba/Stripe_Logo%2C_revised_2016.svg"
                             alt="Powered by Stripe" height="24" class="opacity-50" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden form submitted after JS confirms payment -->
<form id="success-form" asp-action="PaymentSuccess" asp-controller="Orders" method="post" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="orderId" id="success-order-id" value="@orderId" />
</form>

<style>
    .checkout-container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }

    .checkout-steps {
        display: flex; align-items: center; justify-content: center;
    }
    .step {
        display: flex; flex-direction: column; align-items: center; gap: .3rem;
        font-size: .8rem; color: #aaa; min-width: 70px;
    }
    .step.active .step-circle { background: #0d6efd; color: #fff; }
    .step.done  .step-circle  { background: #198754; color: #fff; }
    .step-circle {
        width: 36px; height: 36px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: #e9ecef; font-weight: 700; font-size: .9rem;
    }
    .step-line           { flex: 1; height: 2px; background: #dee2e6; margin: 0 .5rem; margin-bottom: 1.2rem; }
    .step-line.done-line { background: #198754; }

    #payment-element {
        padding: 1rem;
        border: 1px solid #dee2e6;
        border-radius: .5rem;
        background: #fafafa;
    }
</style>

@section Scripts {
<script src="https://js.stripe.com/v3/"></script>
<script>
    (async () => {
        const stripe        = Stripe('@publishableKey');
        const clientSecret  = '@clientSecret';

        const elements = stripe.elements({ clientSecret });

        const paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');

        const payBtn     = document.getElementById('pay-btn');
        const payText    = document.getElementById('pay-btn-text');
        const paySpinner = document.getElementById('pay-spinner');
        const msgBox     = document.getElementById('payment-message');

        payBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            setLoading(true);
            msgBox.classList.add('d-none');

            const { error } = await stripe.confirmPayment({
                elements,
                confirmParams: { return_url: window.location.origin }, // fallback
                redirect: 'if_required'
            });

            if (error) {
                msgBox.textContent = error.message;
                msgBox.classList.remove('d-none');
                setLoading(false);
            } else {
                // Payment succeeded — submit the server-side success form
                document.getElementById('success-form').submit();
            }
        });

        function setLoading(isLoading) {
            payBtn.disabled = isLoading;
            payText.classList.toggle('d-none', isLoading);
            paySpinner.classList.toggle('d-none', !isLoading);
        }
    })();
</script>
}
